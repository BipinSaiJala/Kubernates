# ================================================================
# FILE 1: secret-store.yaml
# ================================================================
# This tells External Secrets Operator:
#   - WHERE is your AWS account
#   - HOW to authenticate to AWS
#   - WHICH region to look in
#
# Think of this as the "connection config" to AWS.
# You create this ONCE per cluster, reuse for all secrets.
# ================================================================
apiVersion: external-secrets.io/v1beta1
kind: SecretStore
metadata:
  name: aws-secret-store        # you give it any name
  namespace: prod
spec:
  provider:
    aws:
      service: SecretsManager   # telling ESO: use AWS Secrets Manager
      region: us-east-1         # which AWS region your secrets live in
      auth:
        jwt:
          serviceAccountRef:
            name: eso-service-account  # a Kubernetes ServiceAccount that
                                       # has IAM permissions to read from
                                       # AWS Secrets Manager
                                       # (set up by your cloud/infra team)

---
# ================================================================
# FILE 2: external-secret.yaml
# ================================================================
# This tells External Secrets Operator:
#   - WHICH secret to fetch from AWS
#   - WHAT to name the Kubernetes Secret it creates
#   - HOW to map AWS secret fields to Kubernetes Secret keys
#
# This is what you create per application/service.
# ================================================================
apiVersion: external-secrets.io/v1beta1
kind: ExternalSecret
metadata:
  name: payment-api-external-secret
  namespace: prod
spec:
  refreshInterval: 1h             # re-fetch from AWS every hour
                                  # if value rotates in AWS, pod gets
                                  # updated value within 1 hour

  secretStoreRef:
    name: aws-secret-store        # points to FILE 1 above
    kind: SecretStore

  target:
    name: payment-api-secret      # THIS is the Kubernetes Secret
                                  # that ESO will CREATE automatically
                                  # your pod will mount THIS secret
    creationPolicy: Owner         # ESO owns this secret — if you delete
                                  # the ExternalSecret, this gets deleted too

  data:
    # Mapping: take this field from AWS, put it in the K8s Secret with this key
    - secretKey: db_password      # key name inside the Kubernetes Secret
      remoteRef:
        key: prod/payment-api/database    # the secret NAME in AWS Secrets Manager
        property: db_password             # the field INSIDE that AWS secret

    - secretKey: db_host          # another key in the same Kubernetes Secret
      remoteRef:
        key: prod/payment-api/database    # same AWS secret
        property: db_host                 # different field from it

